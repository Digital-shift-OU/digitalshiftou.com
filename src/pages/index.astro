---
import {
  ArrowUpRight,
  CalendarDays,
  Code2,
  Dog,
  FileText,
  Gamepad2,
  Heart,
  Menu,
  Rocket,
  ShieldCheck,
  Smartphone,
  Wrench,
} from 'lucide-astro';
import '../styles/global.css';

const liveProducts = [
  {
    name: 'Capgo',
    url: 'https://capgo.app',
    badge: 'Live product',
    icon: Rocket,
    color: '#1f7a55',
    screenshot: '/screenshots/capgo.webp',
    description:
      'Open-source live updates and native build tooling for Capacitor apps, built for teams that need to ship fixes without waiting for app store review.',
    tags: ['Capacitor', 'Live updates', 'SaaS'],
  },
  {
    name: 'BeWise',
    url: 'https://bewise.love',
    badge: 'Live product',
    icon: Heart,
    color: '#c43f72',
    screenshot: '/screenshots/bewise.webp',
    description:
      'A daily motivation app that brings short, useful encouragement to the phone with a focused mobile experience.',
    tags: ['iOS', 'Motivation', 'Wellness'],
  },
  {
    name: 'Memesis',
    url: 'https://memesis.fun',
    badge: 'Party app',
    icon: Gamepad2,
    color: '#6d4aff',
    screenshot: '/screenshots/memesis.webp',
    description:
      'A fast mime game for friends and family, designed around quick rounds, simple rules, and group play from one phone.',
    tags: ['Game', 'Friends', 'Mobile'],
  },
];

const upcomingProducts = [
  {
    name: 'Festival App',
    badge: 'Coming next',
    icon: CalendarDays,
    color: '#d97706',
    screenshot: '/screenshots/festival.webp',
    description:
      'A mobile companion for festival schedules, stages, artists, maps, and last-minute updates.',
  },
  {
    name: 'Devis Facile',
    badge: 'Coming next',
    icon: FileText,
    color: '#2563eb',
    screenshot: '/screenshots/devis-facile.webp',
    description:
      'A simple quote builder for independents and small teams that need clean estimates without spreadsheet drift.',
  },
  {
    name: 'Dogfood Scanner',
    badge: 'Coming next',
    icon: Dog,
    color: '#1f7a55',
    screenshot: '/screenshots/dogfood-scanner.webp',
    description:
      'A label scanner that helps dog owners read ingredients and compare food quality from the aisle.',
  },
];

const methods = [
  {
    title: 'Web tech at the core',
    icon: Code2,
    color: '#2563eb',
    description:
      'We build mobile apps from HTML, CSS, and JavaScript, then package them for app stores with native capabilities where they matter.',
  },
  {
    title: 'Small product loops',
    icon: Smartphone,
    color: '#c45b1c',
    description:
      'Every app starts with the smallest useful workflow, ships quickly, and grows from real usage instead of speculative complexity.',
  },
  {
    title: 'Release discipline',
    icon: ShieldCheck,
    color: '#1f7a55',
    description:
      'We keep delivery practical: clean interfaces, observable releases, and update paths that do not block on store review for every fix.',
  },
];

const productCount = liveProducts.length + upcomingProducts.length + 1;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Digital Shift OU - Web Tech Mobile Apps</title>
    <meta
      name="description"
      content="Digital Shift OU builds mobile apps based on web technologies: HTML, CSS, and JavaScript. Products include Capgo, BeWise, Memesis, and more to come."
    />
    <link rel="icon" href="/logo.svg" type="image/svg+xml" />
    <meta property="og:title" content="Digital Shift OU" />
    <meta
      property="og:description"
      content="Mobile apps built with web technologies: HTML, CSS, and JavaScript."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://digitalshiftou.com" />
    <meta property="og:image" content="https://digitalshiftou.com/screenshots/hero.webp" />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="section-inner header-inner">
          <a class="brand" href="/" aria-label="Digital Shift OU home">
            <img src="/logo.svg" alt="" />
            <span>Digital Shift OU</span>
          </a>

          <nav class="desktop-nav" aria-label="Main navigation">
            <a href="#products">Products</a>
            <a href="#upcoming">Coming next</a>
            <a href="#method">How we build</a>
            <a href="#legacy">Forgr</a>
          </nav>

          <details class="mobile-nav">
            <summary aria-label="Open navigation">
              <Menu class="menu-icon" aria-hidden="true" />
            </summary>
            <nav class="mobile-panel" aria-label="Mobile navigation">
              <a href="#products">Products</a>
              <a href="#upcoming">Coming next</a>
              <a href="#method">How we build</a>
              <a href="#legacy">Forgr</a>
            </nav>
          </details>
        </div>
      </header>

      <main>
        <section class="hero" aria-labelledby="hero-title">
          <div class="section-inner hero-content">
            <p class="eyebrow">Mobile apps built from the web stack.</p>
            <h1 id="hero-title">Digital Shift OU</h1>
            <p class="hero-copy">
              We build focused mobile apps based on HTML, CSS, and JavaScript. The same web
              foundation lets us move fast, keep interfaces sharp, and ship across platforms with
              less product debt.
            </p>
            <div class="hero-actions">
              <a class="button button-primary" href="#products">
                See the apps
                <ArrowUpRight aria-hidden="true" />
              </a>
              <a class="button button-secondary" href="https://github.com/Digital-shift-OU">
                GitHub
                <ArrowUpRight aria-hidden="true" />
              </a>
            </div>
            <div class="stats" aria-label="Digital Shift OU highlights">
              <div class="stat">
                <strong>{productCount}</strong>
                <span>Products listed</span>
              </div>
              <div class="stat">
                <strong>HTML CSS JS</strong>
                <span>Core app stack</span>
              </div>
              <div class="stat">
                <strong>More</strong>
                <span>Apps in progress</span>
              </div>
            </div>
          </div>
        </section>

        <section class="section" id="products" aria-labelledby="products-title">
          <div class="section-inner">
            <div class="section-heading">
              <h2 id="products-title">Apps we made.</h2>
              <p>
                Current products range from developer infrastructure to consumer apps and party
                games. Each one is built with a web-first product loop and shipped as a mobile-grade
                experience.
              </p>
            </div>

            <div class="product-grid">
              {
                liveProducts.map((product) => {
                  const Icon = product.icon;
                  return (
                    <article class="product-card" style={`--product-color: ${product.color}`}>
                      <div class="product-shot">
                        <img src={product.screenshot} alt="" />
                      </div>
                      <div class="product-body">
                        <div class="product-title-row">
                          <div class="product-name">
                            <Icon aria-hidden="true" />
                            <h3>{product.name}</h3>
                          </div>
                          <span class="badge">{product.badge}</span>
                        </div>
                        <p>{product.description}</p>
                        <ul class="tag-list" role="list">
                          {product.tags.map((tag) => <li>{tag}</li>)}
                        </ul>
                        <a class="text-link" href={product.url}>
                          Open product
                          <ArrowUpRight aria-hidden="true" />
                        </a>
                      </div>
                    </article>
                  );
                })
              }
            </div>
          </div>
        </section>

        <section class="section section-muted" id="upcoming" aria-labelledby="upcoming-title">
          <div class="section-inner">
            <div class="section-heading">
              <h2 id="upcoming-title">More to come.</h2>
              <p>
                The next batch keeps the same constraint: useful mobile workflows, web technology
                underneath, and no unnecessary platform ceremony.
              </p>
            </div>

            <div class="upcoming-grid">
              {
                upcomingProducts.map((product) => {
                  const Icon = product.icon;
                  return (
                    <article class="upcoming-card" style={`--product-color: ${product.color}`}>
                      <div class="product-shot">
                        <img src={product.screenshot} alt="" />
                      </div>
                      <div class="product-body">
                        <div class="product-title-row">
                          <div class="product-name">
                            <Icon aria-hidden="true" />
                            <h3>{product.name}</h3>
                          </div>
                          <span class="badge">{product.badge}</span>
                        </div>
                        <p>{product.description}</p>
                      </div>
                    </article>
                  );
                })
              }
            </div>
          </div>
        </section>

        <section class="section" id="method" aria-labelledby="method-title">
          <div class="section-inner">
            <div class="section-heading">
              <h2 id="method-title">Mobile apps, web mechanics.</h2>
              <p>
                We use web technology because it is fast to iterate, easy to inspect, and portable.
                Native work stays focused on the parts that make the product better.
              </p>
            </div>

            <div class="method-grid">
              {
                methods.map((item) => {
                  const Icon = item.icon;
                  return (
                    <div class="method-item" style={`--method-color: ${item.color}`}>
                      <Icon aria-hidden="true" />
                      <h3>{item.title}</h3>
                      <p>{item.description}</p>
                    </div>
                  );
                })
              }
            </div>
          </div>
        </section>

        <section class="section section-muted" id="legacy" aria-labelledby="legacy-title">
          <div class="section-inner">
            <div class="legacy">
              <div class="legacy-media">
                <img src="/screenshots/forgr.webp" alt="" />
              </div>
              <div class="legacy-copy" style="--product-color: #c45b1c">
                <p class="legacy-kicker">
                  <Wrench aria-hidden="true" />
                  Former product
                </p>
                <h2 id="legacy-title">Forgr is part of the history.</h2>
                <p>
                  We also made Forgr, the MVP agency at forgr.ee. We do not sell it anymore, but it
                  shaped the way Digital Shift OU builds: clear scope, tight execution, and useful
                  products over heavy process.
                </p>
                <a class="text-link" href="https://forgr.ee">
                  View Forgr
                  <ArrowUpRight aria-hidden="true" />
                </a>
              </div>
            </div>
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <div class="section-inner footer-inner">
          <a class="footer-logo" href="/" aria-label="Digital Shift OU home">
            <img src="/logo.svg" alt="" />
            <span>Digital Shift OU</span>
          </a>
          <nav class="footer-links" aria-label="Footer navigation">
            <a href="https://github.com/Digital-shift-OU">GitHub</a>
            <a href="https://capgo.app">Capgo</a>
            <a href="https://bewise.love">BeWise</a>
            <span>© {year}</span>
          </nav>
        </div>
      </footer>
    </div>
  </body>
</html>
